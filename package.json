{
  "name": "portfolio",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10"
  },
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "start": "npm run --workspace @portfolio/web dev",
    "dev": "npm run --workspace @portfolio/web dev",
    "build": "npm run --workspace @portfolio/web build",
    "preview": "npm run --workspace @portfolio/web preview",
    "test": "npm run --workspace @portfolio/web test",
    "test:e2e": "npm run --workspace @portfolio/web test:e2e",
    "lint": "npm run --workspace @portfolio/web lint",
    "format": "npm run --workspace @portfolio/web format",
    "check": "npm run --workspace @portfolio/web check",
    "journal": "gulp journal:generate",
    "docs:serve": "gulp mkdocs:serve",
    "docs:stop": "gulp mkdocs:stop",
    "docs:build": "gulp mkdocs:build",
    "vault:encrypt": "gulp vault:encrypt",
    "vault:decrypt": "gulp vault:decrypt",
    "vault:view": "gulp vault:view",
    "vault:rekey": "gulp vault:rekey",
    "claude:yolo": "claude --dangerously-skip-permissions",
    "copilot:yolo": "copilot --allow-all-tools",
    "codex:yolo": "codex --yolo",
    "gemini:yolo": "gemini --yolo",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/k2works/portfolio.git"
  },
  "keywords": [
    "portfolio",
    "astro",
    "ssg",
    "heroku"
  ],
  "author": "k2works",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/k2works/portfolio/issues"
  },
  "homepage": "https://github.com/k2works/portfolio#readme",
  "dependencies": {
    "dotenv": "^17.4.2",
    "gulp": "^5.0.0"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  },
  "lint-staged": {
    "apps/web/**/*.{astro,ts,tsx,js,jsx,mjs,cjs}": [
      "prettier --write",
      "node scripts/lint-staged-eslint.mjs"
    ],
    "apps/web/**/*.{md,mdx,json,jsonc,html,css}": [
      "prettier --write"
    ]
  }
}
