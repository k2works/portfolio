---
import BaseLayout from "../layouts/BaseLayout.astro";

const profile = {
  name: "k2works",
  role: "Software Engineer",
  catchCopy: "ドメインを段階的に解きほぐすバックエンド主軸のエンジニア",
  specialties: ["Backend", "DDD", "TDD", "AWS", "Java", "TypeScript", "Astro"],
  highlight: "経験 10 年 / 受託・自社プロダクトで 12 案件",
};

const featuredWorks = [
  {
    title: "Work A（サンプル）",
    period: "2024-04 〜 2025-03",
    summary: "金融系バックエンド API のドメインモデル再構築（DDD / TDD 浸透）。",
    tech: ["TypeScript", "AWS", "Terraform"],
  },
  {
    title: "Work B（サンプル）",
    period: "2023-04 〜 2024-03",
    summary: "管理画面のフロントエンド刷新。React + Tailwind で UX を改善。",
    tech: ["React", "TypeScript", "Tailwind"],
  },
  {
    title: "Work C（サンプル）",
    period: "2022-10 〜 2023-09",
    summary: "ポートフォリオサイト本体（本リポジトリ）。Astro SSG + Heroku 配信。",
    tech: ["Astro", "Cloudflare", "Heroku"],
  },
];

const skillsHighlights = [
  {
    category: "Backend",
    items: ["Java / Spring", "TypeScript / Node.js", "Python"],
  },
  { category: "Frontend", items: ["React", "Astro", "Tailwind CSS"] },
  {
    category: "Infrastructure",
    items: ["AWS", "Docker / Kubernetes", "Terraform"],
  },
];
---

<BaseLayout
  title={`${profile.name} | ${profile.role}`}
  description={`${profile.catchCopy} ${profile.highlight}`}
>
  <section class="hero">
    <h1>{profile.name}</h1>
    <p class="role">{profile.role}</p>
    <p class="catch-copy"><strong>{profile.catchCopy}</strong></p>
    <ul class="specialties" aria-label="得意領域">
      {profile.specialties.map((s) => <li>{s}</li>)}
    </ul>
    <p class="highlight">{profile.highlight}</p>
    <p class="cta">
      <a href="/works/">Works を見る →</a>
      <a href="/contact/">Contact</a>
    </p>
  </section>

  <section class="featured" aria-labelledby="featured-heading">
    <h2 id="featured-heading">Featured Works</h2>
    <ul class="works-grid">
      {
        featuredWorks.map((work) => (
          <li>
            <article data-testid="work-card">
              <h3>{work.title}</h3>
              <p class="meta">{work.period}</p>
              <p>{work.summary}</p>
              <ul class="tech-tags" aria-label="使用技術">
                {work.tech.map((t) => (
                  <li>{t}</li>
                ))}
              </ul>
            </article>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="skills" aria-labelledby="skills-heading">
    <h2 id="skills-heading">Skills Highlights</h2>
    <div class="skills-grid">
      {
        skillsHighlights.map((group) => (
          <div>
            <h3>{group.category}</h3>
            <ul>
              {group.items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    margin-bottom: 3rem;
  }
  .hero h1 {
    margin-bottom: 0.25rem;
  }
  .role {
    font-size: 1.125rem;
    color: gray;
    margin: 0 0 0.5rem;
  }
  .catch-copy {
    font-size: 1.25rem;
    margin: 0.75rem 0;
  }
  .specialties {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0.75rem 0;
  }
  .specialties li {
    border: 1px solid currentColor;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    font-size: 0.875rem;
  }
  .highlight {
    font-weight: 600;
  }
  .cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .cta a {
    border: 1px solid currentColor;
    padding: 0.5rem 1rem;
    text-decoration: none;
    border-radius: 0.25rem;
  }
  .featured {
    margin-bottom: 3rem;
  }
  .works-grid {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 768px) {
    .works-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .works-grid article {
    border: 1px solid currentColor;
    padding: 1rem;
    border-radius: 0.5rem;
    height: 100%;
  }
  .works-grid h3 {
    margin: 0 0 0.25rem;
  }
  .meta {
    color: gray;
    font-size: 0.875rem;
    margin: 0 0 0.5rem;
  }
  .tech-tags {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    margin: 0.5rem 0 0;
  }
  .tech-tags li {
    background: rgba(125, 125, 125, 0.15);
    padding: 0.125rem 0.5rem;
    font-size: 0.75rem;
    border-radius: 0.25rem;
  }
  .skills-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
  }
  @media (min-width: 768px) {
    .skills-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .skills-grid ul {
    list-style: disc;
    padding-left: 1.25rem;
  }
</style>
