---
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

type Work = CollectionEntry<"works">;
type Skill = CollectionEntry<"skills">;

const profile = {
  name: "k2works",
  role: "Software Engineer",
  catchCopy: "内製開発 10 数年、よいソフトウェアを探求せし \n絶滅危惧種 XP おじさん",
  catchLink: {
    href: "https://alu.jp/series/%E3%83%99%E3%83%AB%E3%82%BB%E3%83%AB%E3%82%AF/crop/0bTcJtFIwaKRapCLxFHY",
    label: "ブログで使えるベルセルクのコマ（ALU）",
  },
  specialties: ["Backend", "DDD", "TDD", "AWS", "Java", "TypeScript", "Ruby on Rails", "XP"],
  highlight: "経験 20 年 / 社内開発 15 年",
};

// Featured Works: Content Collections から featured: true を取得（最大 3 件）
const allWorks = await getCollection("works");
const featuredWorks = allWorks
  .filter((w: Work) => w.data.featured)
  .sort((a: Work, b: Work) => b.data.period.from.localeCompare(a.data.period.from))
  .slice(0, 3);

const formatPeriod = (work: Work): string => {
  const to = work.data.period.to ?? "現在";
  return `${work.data.period.from} 〜 ${to}`;
};

// Skills Highlights: Skills Content Collection からカテゴリ別に集計（Backend / Frontend / Infrastructure の上位 3 件）
const allSkills = await getCollection("skills");
const HIGHLIGHT_CATEGORIES = ["Backend", "Frontend", "Infrastructure"] as const;
type HighlightCategory = (typeof HIGHLIGHT_CATEGORIES)[number];

const skillsByCategory = new Map<HighlightCategory, Skill[]>();
HIGHLIGHT_CATEGORIES.forEach((c) => skillsByCategory.set(c, []));
allSkills.forEach((s: Skill) => {
  const list = skillsByCategory.get(s.data.category as HighlightCategory);
  if (list) list.push(s);
});
skillsByCategory.forEach((list) => {
  list.sort((a: Skill, b: Skill) => {
    const ao = a.data.order ?? 999;
    const bo = b.data.order ?? 999;
    if (ao !== bo) return ao - bo;
    return a.data.name.localeCompare(b.data.name);
  });
});

const skillsHighlights = HIGHLIGHT_CATEGORIES.map((category) => ({
  category,
  items: (skillsByCategory.get(category) ?? []).slice(0, 3).map((s) => s.data.name),
}));
---

<BaseLayout
  title={`${profile.name} | ${profile.role}`}
  description={`${profile.catchCopy.replace(/\n/g, " ")} ${profile.highlight}`}
>
  <section class="mb-12">
    <h1 class="m-0 text-4xl font-bold tracking-tight sm:text-5xl">{profile.name}</h1>
    <p class="mt-1 text-lg text-[color:var(--color-muted)]">{profile.role}</p>
    <figure class="mt-4 max-w-full">
      <iframe
        src="https://alu.jp/series/%E3%83%99%E3%83%AB%E3%82%BB%E3%83%AB%E3%82%AF/crop/embed/0bTcJtFIwaKRapCLxFHY/0?referer=oembed"
        width="600"
        height="281.6"
        scrolling="no"
        loading="lazy"
        title="ブログで使えるベルセルクのコマ（ALU 公式埋め込み）"
        referrerpolicy="no-referrer-when-downgrade"
        style="margin: auto; display: block; border-width: 0px; max-width: 100%; aspect-ratio: 600 / 281.6;"
        data-testid="catch-embed"></iframe>
      <figcaption class="mt-1 text-center text-xs text-[color:var(--color-muted)]">
        出典:
        <a
          href={profile.catchLink.href}
          target="_blank"
          rel="noopener noreferrer"
          class="underline-offset-4 hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[color:var(--color-accent)]"
          data-testid="catch-link"
        >
          {profile.catchLink.label} ↗
        </a>
      </figcaption>
    </figure>
    <p class="mt-4 text-xl whitespace-pre-line"><strong>{profile.catchCopy}</strong></p>
    <ul class="mt-3 flex flex-wrap gap-2" aria-label="得意領域">
      {
        profile.specialties.map((s) => (
          <li class="rounded-full border border-[color:var(--color-border)] px-3 py-1 text-sm">
            {s}
          </li>
        ))
      }
    </ul>
    <p class="mt-3 font-semibold">{profile.highlight}</p>
    <p class="mt-5 flex flex-wrap gap-3">
      <a
        href="/works/"
        class="rounded border border-[color:var(--color-border)] px-4 py-2 no-underline transition-opacity hover:opacity-80 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
      >
        Works を見る →
      </a>
      <a
        href="/contact/"
        class="rounded border border-[color:var(--color-border)] px-4 py-2 no-underline transition-opacity hover:opacity-80 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
      >
        Contact
      </a>
    </p>
  </section>

  <section class="mb-12" aria-labelledby="featured-heading">
    <h2 id="featured-heading" class="text-2xl font-bold">Featured Works</h2>
    <ul class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        featuredWorks.map((work: Work) => {
          const techs = work.data.tech as string[];
          return (
            <li class="m-0 list-none">
              <article
                data-testid="work-card"
                class="flex h-full flex-col rounded-lg border border-[color:var(--color-border)] p-4 transition-shadow hover:shadow-md"
              >
                <h3 class="m-0 text-lg font-semibold">
                  <a href={`/works/${work.slug}/`} class="no-underline hover:underline">
                    {work.data.title}
                  </a>
                </h3>
                <p class="mt-1 text-sm text-[color:var(--color-muted)]">{formatPeriod(work)}</p>
                <p class="mt-2 text-sm">{work.data.summary}</p>
                <ul class="mt-3 flex flex-wrap gap-1" aria-label="使用技術">
                  {techs.map((t) => (
                    <li class="rounded bg-black/5 px-2 py-0.5 text-xs dark:bg-white/10">{t}</li>
                  ))}
                </ul>
              </article>
            </li>
          );
        })
      }
    </ul>
    <p class="mt-4 text-sm">
      <a href="/works/" class="text-[color:var(--color-accent)]"> Works 一覧へ → </a>
    </p>
  </section>

  <section class="mb-12" aria-labelledby="skills-heading">
    <h2 id="skills-heading" class="text-2xl font-bold">Skills Highlights</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        skillsHighlights.map((group) => (
          <div class="rounded-lg border border-[color:var(--color-border)] p-4">
            <h3 class="m-0 text-base font-semibold">{group.category}</h3>
            <ul class="mt-2 list-disc pl-5 text-sm">
              {group.items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
    <p class="mt-4 text-sm">
      <a href="/skills/" class="text-[color:var(--color-accent)]"> Skills 一覧へ → </a>
    </p>
  </section>

  <section aria-labelledby="books-heading">
    <h2 id="books-heading" class="text-2xl font-bold">Books</h2>
    <p class="mt-2 text-[color:var(--color-muted)]">
      技術 / ビジネス / チームの 3 軸 × 6 カテゴリで分類した読書リスト 77 冊。
    </p>
    <p class="mt-3 text-sm">
      <a href="/books/" class="text-[color:var(--color-accent)]"> 知識バックグラウンドを見る → </a>
    </p>
  </section>
</BaseLayout>
