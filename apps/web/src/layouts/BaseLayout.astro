---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;

const siteName = "Portfolio";
const fallbackDescription =
  "採用・営業向け個人ポートフォリオ。経歴 / 実績 / スキル / 連絡先を Markdown ベースで管理しています。";
const finalDescription = description ?? fallbackDescription;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();

const navItems = [
  { href: "/", label: "Home" },
  { href: "/works/", label: "Works" },
  { href: "/skills/", label: "Skills" },
  { href: "/contact/", label: "Contact" },
  { href: "/docs/", label: "Tech Notes ↗" },
];

const currentPath = Astro.url.pathname;
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={finalDescription} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={finalDescription} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content={siteName} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={finalDescription} />
  </head>
  <body class="font-sans">
    <a href="#main" class="skip-link">メインコンテンツへ移動</a>

    <header
      class="sticky top-0 z-10 border-b border-[color:var(--color-border)] bg-bg/95 backdrop-blur"
    >
      <div class="mx-auto flex max-w-prose flex-wrap items-center gap-4 px-4 py-3">
        <a href="/" class="font-bold no-underline" aria-label="ホームへ">{siteName}</a>
        <nav class="ml-auto" aria-label="メインナビゲーション">
          <ul class="flex flex-wrap gap-3 sm:gap-4">
            {
              navItems.map((item) => {
                const isCurrent =
                  item.href === "/" ? currentPath === "/" : currentPath.startsWith(item.href);
                return (
                  <li>
                    <a
                      href={item.href}
                      aria-current={isCurrent ? "page" : undefined}
                      class={
                        "no-underline transition-opacity hover:opacity-80 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-accent" +
                        (isCurrent ? " font-bold underline" : "")
                      }
                    >
                      {item.label}
                    </a>
                  </li>
                );
              })
            }
          </ul>
        </nav>
      </div>
    </header>

    <main id="main" class="mx-auto max-w-prose px-4 py-8 sm:py-10 lg:py-12">
      <slot />
    </main>

    <footer
      class="mx-auto mt-16 max-w-prose border-t border-[color:var(--color-border)] px-4 py-6 text-sm text-[color:var(--color-muted)]"
    >
      <p class="m-0">© {year} {siteName}</p>
      <ul class="mt-2 flex flex-wrap gap-4" aria-label="ソーシャルリンク">
        <li>
          <a
            href="https://github.com/k2works"
            target="_blank"
            rel="noopener noreferrer"
            class="focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-accent"
          >
            GitHub ↗
          </a>
        </li>
        <li>
          <a
            href="https://www.linkedin.com/"
            target="_blank"
            rel="noopener noreferrer"
            class="focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-accent"
          >
            LinkedIn ↗
          </a>
        </li>
        <li>
          <a
            href="https://github.com/k2works/portfolio"
            target="_blank"
            rel="noopener noreferrer"
            class="focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-accent"
          >
            このサイトのソース ↗
          </a>
        </li>
      </ul>
    </footer>
  </body>
</html>
